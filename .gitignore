# Secrets — never commit
.env
.env.local
*.local

# Personal Claude Code settings (machine-specific, not shared)
.claude/settings.local.json

# Runtime control files
.paused

# Per-item claim locks (transient, runtime-only)
work/**/.lock

# Build spec / PRD — local reference only, never upload
agent-brain-spec.md

# OS / tooling cruft
.DS_Store
node_modules/

# Machine-specific / runtime artifacts (not shared)
# Playwright MCP runtime output
.playwright-mcp/
# Obsidian vault workspace state
memory/.obsidian/
# VS Code multi-root view (see dev-setup-dual-repo)
*.code-workspace
# Stray root-level QA screenshots; durable images live under projects/ or memory/
/*.png

# --- Tracked by default ---
# work/archived/, memory/archive/, and memory/reports/ are committed so the
# agent's provenance and digests survive. Uncomment below to stop tracking them
# if they ever grow too large for the repo.
# work/archived/
# memory/archive/
# memory/reports/
