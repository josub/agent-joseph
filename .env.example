# Copy this file to .env and fill in any keys your skills need.
# The boilerplate requires NONE of these — they are placeholders only.
# .env is gitignored; never commit real secrets, and never copy them into
# memory, the wiki, any tracked file, or a clone (see CLAUDE.md guardrail 4).

# Example: a web-search or LLM provider key a learned skill might use.
# SEARCH_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: identify this agent in claim stamps for a multi-agent fleet.
# AGENT_ID=agent-brain
